# .env.example
#
# Copy to .env.local for local development.
# Never commit .env.local or any file containing real secrets.
#
# Secret management:
#  - Local dev: varlock pull --env development > .env.local
#  - Production: SST secrets (set via: pnpm sst secret set <Name> "<value>")

# ---- Database ----------------------------------------------------------------
# Supabase PostgreSQL connection string.
# Append ?pgBouncer=true for Lambda deployments (transaction pooling mode).
# Local dev can omit the pgBouncer param.
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# ---- Payload CMS -------------------------------------------------------------
# Random 32+ character string — used to sign Payload's JWT tokens.
# Generate: openssl rand -hex 32
PAYLOAD_SECRET=<random-32-char-string>

# ---- Next.js -----------------------------------------------------------------
# The public-facing URL of the deployed app.
# Used by Payload for media URL generation and admin panel links.
# Local dev: http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ---- AWS S3 (production only) -----------------------------------------------
# In Lambda, IAM role credentials are injected automatically by SST.
# Only needed for local dev if testing S3 storage locally.
# Leave blank to use local filesystem storage in development.
S3_BUCKET=<bucket-name>
S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=<only-needed-for-local-s3-testing>
# AWS_SECRET_ACCESS_KEY=<only-needed-for-local-s3-testing>
