# ─── Dependencies ─────────────────────────────────────────────────────────────
# No leading slash — matches node_modules/ at any depth (root, cms/, sub-packages)
node_modules/

# ─── Environment & secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem

# ─── Build outputs ────────────────────────────────────────────────────────────
/build/
/dist/
/.react-router/

# ─── Cloudflare / Wrangler ────────────────────────────────────────────────────
.wrangler/

# ─── Test & coverage ──────────────────────────────────────────────────────────
/coverage/
lhci_reports/

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/

# ─── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
pnpm-debug.log*
npm-debug.log*

# ─── Claude Code ──────────────────────────────────────────────────────────────
.claude/
/agents/docs/local/
