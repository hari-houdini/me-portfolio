# ─── Dependencies ─────────────────────────────────────────────────────────────
# No leading slash — matches node_modules/ at any depth (root, cms/, sub-packages)
node_modules/
.next/

# ─── Environment & secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem

# ─── Build outputs ────────────────────────────────────────────────────────────
/build/
/dist/
/.react-router/
.next

# ─── Cloudflare / Wrangler ────────────────────────────────────────────────────
.wrangler/

# ─── Test & coverage ──────────────────────────────────────────────────────────
/coverage/
lhci_reports/

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/

# ─── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
pnpm-debug.log*
npm-debug.log*

# ─── CMS (Payload + Next.js) ──────────────────────────────────────────────────
/cms/node_modules/
/cms/.next/
/cms/media/
/cms/.env
/cms/payload-types.ts

# ─── Claude Code ──────────────────────────────────────────────────────────────
.claude/
/agents/docs/local/
