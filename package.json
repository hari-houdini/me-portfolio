{
	"name": "me-portfolio",
	"version": "1.8.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=20.9.0",
		"pnpm": ">=10"
	},
	"scripts": {
		"next:dev": "next dev --no-server-fast-refresh",
		"dev": "varlock run -- pnpm next:dev",
		"build": "next build",
		"start": "next start",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write",
		"lint": "biome lint --write",
		"check": "biome check --write",
		"ci:check": "biome ci .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"deploy": "sst deploy --stage production",
		"deploy:preview": "sst deploy --stage preview",
		"payload:generate-types": "payload generate:types",
		"payload:migrate": "payload migrate",
		"payload:migrate:create": "payload migrate:create",
		"payload:migrate:fresh": "payload migrate:fresh",
		"payload:generate-importmap": "payload generate:importmap",
		"varlock:load": "varlock load --env development",
		"varlock:pull": "varlock pull --env development > .env.local",
		"varlock:push": "varlock push --env development"
	},
	"dependencies": {
		"@gsap/react": "^2.1.2",
		"@payloadcms/db-postgres": "^3.80.0",
		"@payloadcms/next": "^3.80.0",
		"@payloadcms/richtext-lexical": "^3.80.0",
		"@payloadcms/storage-s3": "^3.80.0",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.5.0",
		"@react-three/postprocessing": "^3.0.4",
		"dotted-map": "^3.1.0",
		"effect": "^3.21.0",
		"embla-carousel": "^8.6.0",
		"embla-carousel-react": "^8.6.0",
		"gsap": "^3.14.2",
		"next": "^16.2.1",
		"payload": "^3.80.0",
		"postprocessing": "^6.39.0",
		"react": "^19.0.0",
		"react-aria-components": "^1.16.0",
		"react-dom": "^19.0.0",
		"sharp": "^0.34.5",
		"shiki": "^4.0.2",
		"three": "^0.183.2",
		"three-stdlib": "^2.36.1",
		"varlock": "^0.7.1",
		"zocker": "^3.0.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22.19.15",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@types/three": "^0.183.1",
		"@vitejs/plugin-react": "^4.5.2",
		"@vitest/coverage-v8": "^4.1.0",
		"jsdom": "^29.0.1",
		"msw": "^2.12.13",
		"raw-loader": "^4.0.2",
		"sst": "^4.5.11",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.0"
	}
}
