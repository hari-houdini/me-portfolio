{
	"compilerOptions": {
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"baseUrl": ".",
		"paths": {
			"@app/*": ["./app/*"],
			"@features/*": ["./features/*"],
			"@payload-config": ["./payload.config.ts"],
			"@cms/*": ["./features/cms/*"]
		},
		"target": "ES2017"
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		"next-env.d.ts",
		"sst-env.d.ts",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"next.config.ts"
	],
	"exclude": ["node_modules", ".next", ".sst", "sst.config.ts"]
}
